# Solar Explorer — infrastructure environment variables
#
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# All values below are read by the CDK app at synth/deploy time.

# Fully qualified domain the site is served from.
DOMAIN_NAME=solar.example.com

# Route 53 Hosted Zone that owns the domain above.
HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ
HOSTED_ZONE_NAME=example.com

# AWS target account/region. CloudFront requires the ACM certificate in
# us-east-1, so the stack must be deployed there.
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# AWS credentials profile used by the CDK CLI (read by the AWS SDK, not by
# the stack code). Leave unset to use the default profile / environment creds.
AWS_PROFILE=default
