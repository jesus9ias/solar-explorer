---
// Solar Explorer — main page shell.
// The static HTML provides the mount points and theme. All interactivity is
// wired up client-side in the script below (Phaser canvas + DOM HUD/overlays).
import { getText } from '../logic/i18n';
import { Language } from '../constants/constants';

const title = getText('app.title', Language.EN);
const subtitle = getText('app.subtitle', Language.EN);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <title>{title}</title>
    <meta name="description" content={subtitle} />
  </head>
  <body>
    <h1 class="se-visually-hidden">{title}</h1>
    <div id="game-root"></div>
    <div id="hud-root"></div>
    <div id="mission-root"></div>
    <div id="library-root"></div>
    <div id="modal-root"></div>
    <div id="mission-modal-root"></div>
    <audio id="ambient-audio" loop preload="none">
      <source src="/audio/ambient.ogg" type="audio/ogg" />
      <source src="/audio/ambient.mp3" type="audio/mpeg" />
    </audio>

    <script>
      import Phaser from 'phaser';
      import { LinearScene } from '../game/scenes/LinearScene';
      import { EllipseScene } from '../game/scenes/EllipseScene';
      import { MissionScene } from '../game/scenes/MissionScene';
      import { HUD, type AudioController } from '../ui/HUD';
      import { LibraryModal } from '../ui/LibraryModal';
      import { MissionModal } from '../ui/MissionModal';
      import { MissionPanel } from '../ui/MissionPanel';
      import { userPreferences } from '../state/UserPreferences';
      import { modeState } from '../state/ModeState';
      import { missionState } from '../state/MissionState';
      import { isMissionActive } from '../logic/mission';
      import { sceneKeyForMode, otherSceneKeys } from '../logic/scenes';
      import {
        Mode,
        REGISTRY_ON_SELECT,
        EVENT_LANG_CHANGED,
        EVENT_FOCUS_ELEMENT,
        EVENT_MISSION_START,
        AUDIO_VOLUME,
        COLOR_BG,
      } from '../constants/constants';

      const gameRoot = document.getElementById('game-root');
      const hudRoot = document.getElementById('hud-root');
      const missionRoot = document.getElementById('mission-root');
      const libraryRoot = document.getElementById('library-root');
      const modalRoot = document.getElementById('modal-root');
      const missionModalRoot = document.getElementById('mission-modal-root');
      const audioEl = document.getElementById('ambient-audio') as HTMLAudioElement | null;

      if (gameRoot && hudRoot && missionRoot && libraryRoot && modalRoot && missionModalRoot) {
        const library = new LibraryModal(modalRoot, (id) =>
          game.events.emit(EVENT_FOCUS_ELEMENT, id),
        );

        // Mission overlay (years counter + phase checklist) and the mission modal.
        new MissionPanel(missionRoot);
        const missionModal = new MissionModal(missionModalRoot, (id) => {
          missionState.start(id);
          game.events.emit(EVENT_MISSION_START, id);
        });

        // The first scene in the array auto-starts, so order it by the saved
        // mode. Runtime switching is handled by showScene below.
        const sceneByMode = {
          [Mode.LINEAR]: LinearScene,
          [Mode.ELLIPSE]: EllipseScene,
          [Mode.MISSION]: MissionScene,
        };
        const all = [LinearScene, EllipseScene, MissionScene];
        const first = sceneByMode[modeState.getMode()] ?? LinearScene;
        const initialScenes = [first, ...all.filter((s) => s !== first)];

        const game = new Phaser.Game({
          type: Phaser.AUTO,
          parent: gameRoot,
          backgroundColor: COLOR_BG,
          scale: {
            mode: Phaser.Scale.RESIZE,
            width: window.innerWidth,
            height: window.innerHeight,
          },
          // Only listen for input on the game canvas itself. Without this,
          // Phaser also binds pointer listeners to `window`, so clicks on the
          // DOM overlays (HUD, modal, library) bubble up and trigger a hit-test
          // on whatever body sits underneath — opening the wrong modal.
          input: {
            windowEvents: false,
          },
          scene: initialScenes,
        });

        game.registry.set(REGISTRY_ON_SELECT, (id: string) => library.openById(id));

        const audio: AudioController = {
          setEnabled(enabled: boolean) {
            if (!audioEl) return;
            audioEl.volume = AUDIO_VOLUME;
            if (enabled) void audioEl.play().catch(() => {});
            else audioEl.pause();
          },
          isEnabled() {
            return !!audioEl && !audioEl.paused;
          },
        };

        const hud = new HUD({
          root: hudRoot,
          emit: (event, payload) => game.events.emit(event, payload),
          audio,
          onLibrary: () => library.open(),
          onMissions: () => missionModal.open(),
        });

        const showScene = (mode: Mode) => {
          const target = sceneKeyForMode(mode);
          const manager = game.scene;
          for (const other of otherSceneKeys(target)) {
            if (manager.isActive(other)) manager.stop(other);
          }
          manager.start(target);
        };

        // Open the mission picker on entering Mission mode, but only when no
        // mission is active — returning to a running mission should resume it
        // silently, not pop the picker over it each time.
        const openPickerIfNeeded = () => {
          if (!isMissionActive(missionState.getStatus(), missionState.getSelectedId())) {
            missionModal.open();
          }
        };

        // The correct scene already auto-starts via initialScenes ordering.
        // READY handles deferred audio autoplay and the initial mission picker.
        game.events.once(Phaser.Core.Events.READY, () => {
          if (userPreferences.isAudioEnabled()) audio.setEnabled(true);
          if (modeState.getMode() === Mode.MISSION) openPickerIfNeeded();
        });

        // Runtime mode switches. Entering Mission mode opens the picker unless a
        // mission is already running.
        modeState.subscribe((mode) => {
          showScene(mode);
          if (mode === Mode.MISSION) openPickerIfNeeded();
        });

        userPreferences.subscribe(() => {
          hud.refresh();
          library.refresh();
          missionModal.refresh();
          game.events.emit(EVENT_LANG_CHANGED);
        });
      }
    </script>

    <style is:global>
      :root {
        --se-bg: #05080f;
        --se-panel: #0b1320;
        --se-panel-2: #0f1c2b;
        --se-accent: #3df29b;
        --se-amber: #f2b134;
        --se-text: #cfe3df;
        --se-muted: #6f8a92;
        --se-border: #1d3242;
      }

      * { box-sizing: border-box; }
      [hidden] { display: none !important; }

      html, body {
        margin: 0;
        height: 100%;
        background: var(--se-bg);
        color: var(--se-text);
        font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
        overflow: hidden;
      }

      .se-visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0 0 0 0);
        white-space: nowrap;
        border: 0;
      }

      #game-root { position: fixed; inset: 0; }
      #game-root canvas { display: block; touch-action: none; }

      /* HUD */
      .se-hud {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 14px;
        padding: 10px 14px;
        background: linear-gradient(180deg, rgba(5, 8, 15, 0.95), rgba(5, 8, 15, 0.6));
        border-bottom: 1px solid var(--se-border);
        z-index: 10;
        user-select: none;
      }

      .se-control { display: flex; flex-direction: column; gap: 4px; }
      .se-control-label {
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--se-muted);
      }
      .se-segments { display: flex; border: 1px solid var(--se-border); border-radius: 4px; overflow: hidden; }
      .se-segment {
        flex: 1;
        background: var(--se-panel);
        color: var(--se-text);
        border: none;
        padding: 5px 10px;
        font: inherit;
        font-size: 12px;
        cursor: pointer;
        border-right: 1px solid var(--se-border);
      }
      .se-segment:last-child { border-right: none; }
      .se-segment:hover { background: var(--se-panel-2); }
      .se-segment.is-active { background: var(--se-accent); color: #04140d; font-weight: 700; }

      .se-button {
        align-self: flex-end;
        background: var(--se-panel);
        color: var(--se-accent);
        border: 1px solid var(--se-border);
        border-radius: 4px;
        padding: 6px 12px;
        font: inherit;
        font-size: 12px;
        cursor: pointer;
      }
      .se-button:hover { background: var(--se-panel-2); border-color: var(--se-accent); }

      .se-btn-icon { display: none; }

      /* Modal */
      .se-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(2, 5, 10, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 30;
      }
      .se-modal {
        position: relative;
        width: min(440px, 92vw);
        max-height: 86vh;
        overflow-y: auto;
        background: var(--se-panel);
        border: 1px solid var(--se-border);
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 40px rgba(61, 242, 155, 0.08);
      }
      .se-modal-close {
        position: absolute;
        top: 8px;
        right: 10px;
        background: none;
        border: none;
        color: var(--se-muted);
        font-size: 22px;
        line-height: 1;
        cursor: pointer;
      }
      .se-modal-close:hover { color: var(--se-accent); }
      .se-modal-canvas {
        max-width: 100%;
        display: block;
        margin: 0 auto 10px;
        background: radial-gradient(circle at center, #0a1622, #05080f);
        border-radius: 6px;
      }
      .se-modal-title { margin: 0 0 8px; text-align: center; color: var(--se-text); font-size: 20px; }
      .se-badge {
        display: inline-block;
        margin: 0 auto 10px;
        padding: 3px 10px;
        background: rgba(242, 177, 52, 0.15);
        color: var(--se-amber);
        border: 1px solid var(--se-amber);
        border-radius: 999px;
        font-size: 11px;
        letter-spacing: 0.06em;
      }
      .se-modal-fields { display: grid; grid-template-columns: auto 1fr; gap: 4px 14px; margin: 10px 0; }
      .se-modal-fields dt { color: var(--se-muted); font-size: 12px; }
      .se-modal-fields dd { margin: 0; font-size: 13px; text-align: right; }
      .se-modal-subtitle { margin: 14px 0 4px; font-size: 12px; color: var(--se-accent); letter-spacing: 0.06em; }
      .se-modal-text { margin: 4px 0; font-size: 13px; line-height: 1.5; color: var(--se-text); }
      .se-modal-list { margin: 4px 0; padding-left: 18px; }
      .se-modal-list li { font-size: 13px; line-height: 1.5; margin-bottom: 4px; }

      /* Library modal (two columns) */
      .se-lib-modal {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
        grid-template-rows: minmax(0, 1fr);
        width: min(860px, 94vw);
        height: min(640px, 86vh);
        background: var(--se-panel);
        border: 1px solid var(--se-border);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 0 40px rgba(61, 242, 155, 0.08);
      }
      .se-lib-tabs { display: none; }

      .se-lib-left {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 18px 16px;
        border-right: 1px solid var(--se-border);
        background: var(--se-panel);
        min-height: 0;
      }
      .se-lib-search {
        background: var(--se-panel-2);
        color: var(--se-text);
        border: 1px solid var(--se-border);
        border-radius: 4px;
        padding: 7px 10px;
        font: inherit;
        font-size: 13px;
      }
      .se-lib-search:focus { outline: none; border-color: var(--se-accent); }
      .se-lib-group-control { display: flex; flex-direction: column; gap: 4px; }
      .se-lib-group-label {
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--se-muted);
      }
      .se-lib-list { overflow-y: auto; padding-right: 4px; min-height: 0; }
      .se-lib-group { margin-bottom: 14px; }
      .se-lib-group-title {
        margin: 8px 0 6px;
        font-size: 12px;
        color: var(--se-amber);
        letter-spacing: 0.06em;
      }
      .se-lib-items { display: flex; flex-wrap: wrap; gap: 6px; }
      .se-lib-item {
        background: var(--se-panel-2);
        color: var(--se-text);
        border: 1px solid var(--se-border);
        border-radius: 4px;
        padding: 5px 9px;
        font: inherit;
        font-size: 12px;
        cursor: pointer;
      }
      .se-lib-item:hover { border-color: var(--se-accent); color: var(--se-accent); }
      .se-lib-item.is-selected { border-color: var(--se-accent); background: var(--se-accent); color: #04140d; }
      .se-library-complete { color: var(--se-amber); }

      .se-lib-right {
        display: flex;
        flex-direction: column;
        padding: 20px;
        overflow: hidden;
        min-height: 0;
      }
      .se-info { flex: 1; overflow-y: auto; min-height: 0; }
      .se-info-placeholder {
        color: var(--se-muted);
        font-size: 13px;
        text-align: center;
        margin: 40px 16px;
        line-height: 1.5;
      }
      .se-lib-goto { align-self: stretch; margin-top: 16px; text-align: center; }

      /* Mission overlay (years counter + phase checklist) */
      .se-mission-panel {
        position: fixed;
        left: 14px;
        bottom: 16px;
        z-index: 9;
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-width: 280px;
        pointer-events: none;
        user-select: none;
      }
      .se-mission-counter {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 8px 12px;
        background: linear-gradient(180deg, rgba(11, 19, 32, 0.95), rgba(11, 19, 32, 0.78));
        border: 1px solid var(--se-border);
        border-radius: 8px;
      }
      .se-mission-counter-value {
        font-size: 26px;
        font-weight: 700;
        color: var(--se-amber);
        letter-spacing: 0.02em;
        font-variant-numeric: tabular-nums;
      }
      .se-mission-counter-label {
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--se-muted);
      }
      .se-mission-checklist {
        list-style: none;
        margin: 0;
        padding: 10px 12px;
        background: rgba(11, 19, 32, 0.82);
        border: 1px solid var(--se-border);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        gap: 7px;
      }
      .se-mission-phase {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: var(--se-muted);
        transition: color 0.3s;
      }
      .se-mission-check {
        flex: none;
        width: 15px;
        height: 15px;
        border: 1px solid var(--se-border);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        line-height: 1;
        color: transparent;
      }
      .se-mission-phase.is-done { color: var(--se-text); }
      .se-mission-phase.is-done .se-mission-check {
        border-color: var(--se-accent);
        background: var(--se-accent);
        color: #04140d;
      }
      .se-mission-phase.is-done .se-mission-check::after { content: '✓'; }
      .se-mission-phase-duration {
        flex: none;
        min-width: 48px;
        color: var(--se-amber);
        font-variant-numeric: tabular-nums;
        font-size: 11px;
      }
      .se-mission-prompt { font-size: 12px; color: var(--se-muted); line-height: 1.4; }
      .se-mission-modal-phases { margin: 4px 0; padding-left: 28px; }
      .se-mission-modal-phases li { font-size: 13px; line-height: 1.5; margin-bottom: 4px; padding-left: 4px; }
      .se-mission-active-dot { color: var(--se-accent); }

      /* Mission picker list: one mission per row. */
      .se-mission-list { flex-direction: column; flex-wrap: nowrap; }
      .se-mission-list .se-lib-item { width: 100%; text-align: left; }

      @media (max-width: 640px) {
        .se-hud {
          flex-wrap: nowrap;
          overflow-x: auto;
          gap: 8px;
          padding: 8px 10px;
          scrollbar-width: none;
        }
        .se-hud::-webkit-scrollbar { display: none; }
        .se-control-label { display: none; }
        .se-btn-icon { display: inline; }
        .se-btn-icon ~ .se-btn-text { display: none; }
        .se-button { align-self: center; }

        /* Collapse the two columns into tabs. */
        .se-lib-modal {
          grid-template-columns: 1fr;
          grid-template-rows: auto minmax(0, 1fr);
          width: 94vw;
          height: 86vh;
        }
        .se-lib-tabs {
          display: flex;
          border-bottom: 1px solid var(--se-border);
        }
        .se-lib-tab {
          flex: 1;
          background: var(--se-panel);
          color: var(--se-text);
          border: none;
          border-right: 1px solid var(--se-border);
          padding: 12px 10px;
          font: inherit;
          font-size: 13px;
          cursor: pointer;
        }
        .se-lib-tab:last-child { border-right: none; }
        .se-lib-tab.is-active { background: var(--se-accent); color: #04140d; font-weight: 700; }
        .se-lib-left { border-right: none; }
        .se-lib-modal[data-tab="list"] .se-lib-right { display: none; }
        .se-lib-modal[data-tab="info"] .se-lib-left { display: none; }
      }
    </style>
  </body>
</html>
