# Solar Explorer — frontend environment variables
#
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# Astro only exposes variables prefixed with PUBLIC_ to client code.

# Full domain the app is served from.
PUBLIC_DOMAIN=solar.example.com

# CloudFront distribution ID — used by the deploy workflow to invalidate cache.
PUBLIC_CF_DISTRIBUTION_ID=E1234567890ABC

# AWS region used by the deploy workflow.
PUBLIC_AWS_REGION=us-east-1
